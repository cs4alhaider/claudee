#!/bin/sh
':' //# ; exec "$(command -v bun || command -v node)" "$0" "$@"
'use strict';
/*
 * claudee — an interactive launcher for Claude Code.
 * Copyright 2026 cs4alhaider. Licensed under the Apache License, Version 2.0.
 *
 *   claudee              → wizard: worktree → options → launch
 *   claudee <args...>    → fast passthrough: claude --dangerously-skip-permissions <args...>
 *   claudee auth|mcp|…   → subcommands pass straight through (no skip-perms)
 *
 * This file is just the entry point. The implementation lives in ./lib:
 *   lib/format.js  pure text/color helpers + the git-status badge
 *   lib/git.js     git + session-history helpers
 *   lib/claude.js  the `claude` CLI interface (build args, run/dry-run)
 *   lib/wizard.js  the interactive TUI (state, rendering, input)
 *
 * The two lines above 'use strict' are a sh/JS polyglot: they run this file
 * with Bun if it is installed (faster startup), otherwise Node. Both runtimes
 * ignore the '#!' line and treat the ':' line as a string + comment (no-op),
 * so 'use strict' still applies.
 */
const { buildArgs, runClaudeIn, SUBCOMMANDS } = require('../lib/claude');

// CLAUDEE_TEST=<json state> → print the assembled claude args and exit (tests).
if (process.env.CLAUDEE_TEST) {
  process.stdout.write(buildArgs(JSON.parse(process.env.CLAUDEE_TEST)).join(' ') + '\n');
  process.exit(0);
}

// Fast path: any arguments bypass the menu entirely.
const argv = process.argv.slice(2);
if (argv.length > 0) {
  if (SUBCOMMANDS.has(argv[0])) runClaudeIn(argv);            // e.g. `claudee auth`
  runClaudeIn(['--dangerously-skip-permissions', ...argv]);  // e.g. `claudee -c "…"`
}

// Non-interactive (piped) and not a one-shot preview → passthrough.
if ((!process.stdin.isTTY || !process.stdout.isTTY) && !process.env.CLAUDEE_PREVIEW) {
  runClaudeIn(['--dangerously-skip-permissions']);
}

// Interactive wizard (or one-shot preview). Required lazily so the fast paths
// above never load the TUI or touch git.
require('../lib/wizard').run();
